DATABASE_URL=postgresql://ontoprompt:ontoprompt@db:5432/ontoprompt
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-to-a-random-32-char-string
ENCRYPTION_KEY=
FIRST_ADMIN_USER=admin
FIRST_ADMIN_PASSWORD=changeme123
UPLOADS_DIR=/uploads

# LiteLLM Proxy — 填入需要的 provider key，不用的留空即可
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DASHSCOPE_API_KEY=
# LiteLLM Admin UI (passed via docker-compose environment, not DATABASE_URL)
LITELLM_MASTER_KEY=sk-master-change-me
LITELLM_SALT_KEY=sk-salt-change-me
UI_USERNAME=admin
UI_PASSWORD=admin
# Note: LiteLLM uses its own DB (litellm) — see docker-compose.yml litellm service
